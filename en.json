
import 'package:flutter/material.dart';
import 'package:shared_preferences/shared_preferences.dart';
import '../services/i18n.dart';

class AppState extends ChangeNotifier {
  bool dyslexiaMode = false;
  bool highContrast = false;
  double fontScale = 1.0; // Accessibility font scale
  String localeCode = 'en';
  late I18n i18n;

  Future<void> init() async {
    final sp = await SharedPreferences.getInstance();
    dyslexiaMode = sp.getBool('dyslexiaMode') ?? false;
    highContrast = sp.getBool('highContrast') ?? false;
    fontScale = sp.getDouble('fontScale') ?? 1.0;
    localeCode = sp.getString('locale') ?? 'en';
    i18n = await I18n.load(localeCode);
    notifyListeners();
  }

  Future<void> setLocale(String code) async {
    localeCode = code;
    i18n = await I18n.load(code);
    final sp = await SharedPreferences.getInstance();
    await sp.setString('locale', code);
    notifyListeners();
  }

  Future<void> toggleDyslexia() async {
    dyslexiaMode = !dyslexiaMode;
    final sp = await SharedPreferences.getInstance();
    await sp.setBool('dyslexiaMode', dyslexiaMode);
    notifyListeners();
  }

  Future<void> toggleContrast() async {
    highContrast = !highContrast;
    final sp = await SharedPreferences.getInstance();
    await sp.setBool('highContrast', highContrast);
    notifyListeners();
  }

  Future<void> setFontScale(double value) async {
    fontScale = value;
    final sp = await SharedPreferences.getInstance();
    await sp.setDouble('fontScale', value);
    notifyListeners();
  }
}
