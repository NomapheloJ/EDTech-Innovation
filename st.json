
import 'dart:convert';
import 'package:flutter/services.dart' show rootBundle;

class I18n {
  final Map<String, dynamic> _data;
  I18n(this._data);

  static Future<I18n> load(String code) async {
    final raw = await rootBundle.loadString('assets/locales/' + code + '.json');
    return I18n(json.decode(raw));
  }

  String t(String key) => _data[key] ?? key;
}
